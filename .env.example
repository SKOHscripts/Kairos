# Copiez ce fichier en .env et renseignez vos valeurs.
# Le fichier .env ne doit JAMAIS être committé (voir .gitignore).
# Tous les réglages sont optionnels : l'outil démarre sans aucun .env.

# --- Base de données ---
# Chemin de la base SQLite des tâches (créée automatiquement au premier démarrage).
TASKS_DATABASE_PATH=tasks.db

# --- Import des issues GitLab qui te sont assignées (optionnel, lecture seule) ---
# Deux façons MUTUELLEMENT EXCLUSIVES d'obtenir tes issues GitLab ouvertes comme
# tâches : le cache pilotage (zéro appel réseau, ci-dessous) si tu as aussi
# pilotage-pleiade-gitlab sur ce poste, sinon l'import direct (plus bas) — le
# cache pilotage prime toujours si les deux sont renseignés. Les deux partagent :
GITLAB_ASSIGNEE_USERNAME=

# 1) Intégration avec l'outil de pilotage MSI, si tu l'utilises aussi (lecture
# seule). Chemin vers la base pilotage.db de pilotage-pleiade-gitlab (dépôt
# séparé) : les issues GitLab assignées (cache entretenu par l'onglet Pilotage
# GitLab) apparaissent comme tâches, et le panneau d'édition propose la liaison
# manuelle vers une fiche de dette technique — cette dernière n'existe QUE via
# ce chemin (pas d'équivalent en import direct). Vide = désactivé.
# Ex. : PILOTAGE_DATABASE_PATH=/home/toi/dev/pilotage-pleiade-gitlab/pilotage.db
PILOTAGE_DATABASE_PATH=

# 2) Import direct GitLab (sans pilotage) : cas normal d'un collègue. Appel en
# lecture seule à l'API REST GitLab (token personnel, scope `read_api` suffit).
# Un ou plusieurs projets ("groupe/projet" ou id numérique), séparés par des virgules.
GITLAB_URL=
GITLAB_TOKEN=
GITLAB_PROJECTS=
# Durée (minutes) de mise en cache des issues (anti rate-limiting côté GitLab).
GITLAB_CACHE_TTL_MINUTES=5

# --- Calendrier personnel TimeTree (optionnel) ---
# Identifiants utilisés par le paquet non-officiel timetree-exporter. Laisser vide =
# calendrier désactivé (saisie manuelle des créneaux occupés uniquement).
TIMETREE_EMAIL=
TIMETREE_PASSWORD=
TIMETREE_CALENDAR_CODE=
# Durée (minutes) de mise en cache des créneaux TimeTree (évite le rate-limiting).
TIMETREE_CACHE_TTL_MINUTES=30

# --- Ordonnancement ---
# Durée par défaut (minutes) attribuée à une tâche sans estimation (jamais stockée).
DEFAULT_TASK_DURATION_MINUTES=30
# Marge (minutes) laissée après un créneau occupé (réunion 13h-14h → tâche à 14h05).
MEETING_BUFFER_MINUTES=5
# Bornes (heures, 24h) de la journée de travail.
WORKDAY_START_HOUR=9
WORKDAY_END_HOUR=18

# --- Ordonnancement WSJF : score = (valeur(priorité) + criticité(échéance)) / effort ---
# PRIORITY_VALUE_BASE : base exponentielle d'un cran de priorité, base**(4-priorité).
#   2.0 → P0=16, P1=8, P2=4, P3=2, P4=1. Baisser (1.5) adoucit, monter durcit l'écart.
# URGENCY_HORIZON_DAYS : jours avant échéance où la criticité commence à monter.
# URGENCY_PEAK : poids max de la criticité temporelle (même unité que la valeur ; 8 ≈ P1).
# DEFAULT_FIBONACCI_POINTS : effort d'une tâche sans points ni estimation (dénominateur).
PRIORITY_VALUE_BASE=2.0
URGENCY_HORIZON_DAYS=14
URGENCY_PEAK=8.0
DEFAULT_FIBONACCI_POINTS=3

# --- Creux de l'après-midi (« post-lunch dip », clin d'œil au nom de code 14h55) ---
# Pendant une fenêtre creuse, l'ordonnancement évite de poser des tâches COMPLEXES
# (points de Fibonacci élevés) et fait remonter les tâches légères sur ces heures peu
# propices à la réflexion. L'urgence et les échéances priment toujours ; le score WSJF
# affiché ne change pas (c'est un choix de placement, pas de valeur). Le matin reste
# piloté par l'urgence pure.
# COGNITIVE_DIP_ENABLED : interrupteur global (false = ordonnancement d'urgence pur).
# COGNITIVE_DIP_*_HOUR : fenêtre triangulaire, creux le plus profond au tronc (15h).
#   Décale ces bornes selon ton chronotype (alouette matinale → creux plus tôt).
# COGNITIVE_DIP_PENALTY : force au tronc pour une tâche de 21 points (1.0 → effort ×2,
#   score de placement ÷2) ; 0 = neutralisé même si activé.
COGNITIVE_DIP_ENABLED=true
COGNITIVE_DIP_START_HOUR=13
COGNITIVE_DIP_TROUGH_HOUR=15
COGNITIVE_DIP_END_HOUR=16
COGNITIVE_DIP_PENALTY=1.0

# --- Garde-fous ---
# Seuils (jours) du badge « traîne depuis N j » (échéance dépassée / tâche sans date
# non retouchée), et nombre de tâches à priorité max avant le bandeau de surcharge.
STALE_OVERDUE_DAYS=7
STALE_UNTOUCHED_DAYS=14
PRIORITY_OVERLOAD_THRESHOLD=5

# --- Dashboard de statistiques (/kairos/stats) ---
# Fenêtre (semaines) des indicateurs « récents » (débit hebdomadaire, temps ventilé,
# délais). La calibration de l'estimation et le backlog portent sur tout l'historique.
STATS_WINDOW_WEEKS=8

# --- Alertes de chrono (notification navigateur, opt-in ; contexte sécurisé requis :
# 127.0.0.1/localhost ou HTTPS — sinon repli titre d'onglet + bandeau in-page) ---
TIMER_IDLE_ALERT_MINUTES=180
POMODORO_FOCUS_MINUTES=50

# --- Jours fériés (décalages jour ouvré : récurrence « le N du mois », snooze) ---
HOLIDAYS_FR=true
EXTRA_HOLIDAYS=

# Niveau de log console : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
